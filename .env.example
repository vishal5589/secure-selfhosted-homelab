# ───────────────────────────────────────────────────────────
# Secrets template — COPY to `.env` and fill in real values.
# `.env` is git-ignored. NEVER commit real secrets.
# Each service gets its own scoped key (least privilege — no sharing).
# ───────────────────────────────────────────────────────────

# Host / network
HOST_LAN_IP=192.168.1.10          # placeholder — your Docker host's LAN IP
TZ=Asia/Kuala_Lumpur

# Approval gateway
GATEWAY_API_KEY=replace-me

# Media orchestrators (scoped, per-service)
MOVIE_ORCHESTRATOR_API_KEY=replace-me
TV_ORCHESTRATOR_API_KEY=replace-me

# Indexer manager
INDEXER_API_KEY=replace-me

# Chat bot
BOT_TOKEN=replace-me

# Workflow engine
N8N_ENCRYPTION_KEY=replace-me
N8N_BASIC_AUTH_USER=replace-me
N8N_BASIC_AUTH_PASSWORD=replace-me

# Notification webhooks (treat as secrets)
NOTIFY_WEBHOOK_GENERAL=replace-me
NOTIFY_WEBHOOK_ALERTS=replace-me

# VPN egress (gluetun)
VPN_PROVIDER=replace-me
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=replace-me
WIREGUARD_ADDRESSES=replace-me
SERVER_COUNTRIES=replace-me
